# 版本号
SHOPRO_VERSION=v2.4.1

# 后端接口 - 正式环境。H5 默认同源；Android 白标构建必须通过 SKIT_API_BASE_URL 注入 HTTPS 域名。
SHOPRO_BASE_URL=

# 后端接口 - 体验环境
SHOPRO_TRIAL_BASE_URL=

# 后端接口 - 测试环境（通过 process.env.NODE_ENV = development）
SHOPRO_DEV_BASE_URL=http://127.0.0.1:48080
### SHOPRO_DEV_BASE_URL=http://10.171.1.188:48080
### SHOPRO_DEV_BASE_URL = http://yunai.natapp1.cc

# 文件上传类型：server - 后端上传， client - 前端直连上传，仅支持 S3 服务
SHOPRO_UPLOAD_TYPE=server

# 后端接口前缀（一般不建议调整）
SHOPRO_API_PATH=/app-api

# 后端 websocket 接口前缀
SHOPRO_WEBSOCKET_PATH=/infra/ws

# 开发环境运行端口
SHOPRO_DEV_PORT=3000

# 客户端静态资源地址 空=默认使用服务端指定的CDN资源地址前缀 | local=本地  |  http(s)://xxx.xxx=自定义静态资源地址前缀
SHOPRO_STATIC_URL=http://test.yudao.iocoder.cn
### SHOPRO_STATIC_URL = https://file.sheepjs.com

# 前端 H5 访问域名
SHOPRO_H5_URL=http://127.0.0.1:3000

# 是否开启直播  1 开启直播 | 0 关闭直播
SHOPRO_MPLIVE_ON=0

# 租户ID 默认 1
SHOPRO_TENANT_ID=1

# 短剧广告聚合：gromore | taku
VITE_DRAMA_AD_PROVIDER=taku

# 开发环境允许无原生 SDK 时模拟完整观看，正式环境默认关闭
VITE_DRAMA_MOCK_REWARD_AD=false

# GroMore 激励视频代码位，通过穿山甲 accessTool / GroMore 后台配置后填写
VITE_GROMORE_REWARD_CODE_ID=104223198

# Taku 激励视频广告位
VITE_TAKU_REWARD_PLACEMENT_ID=b6a5c424bbbb6c

# 穿山甲短剧内容 SDK：需要从穿山甲短剧后台下载同名 JSON 并放入 Android assets
VITE_PANGLE_DRAMA_SETTING_FILE=SDK_Setting.json
VITE_DRAMA_REAL_CONTENT_REQUIRED=false
VITE_PANGLE_DRAMA_FREE_SET=8
VITE_PANGLE_DRAMA_LOCK_SET=5
